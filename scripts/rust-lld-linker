#!/usr/bin/env bash
set -euo pipefail

SYSROOT="$(rustc --print sysroot)"
HOST_TRIPLE="$(rustc -vV | sed -n 's/^host: //p')"
LLD_GNU="$SYSROOT/lib/rustlib/$HOST_TRIPLE/bin/gcc-ld/ld.lld"
RUST_LLD="$SYSROOT/lib/rustlib/$HOST_TRIPLE/bin/rust-lld"

if [[ -x "$LLD_GNU" ]]; then
  linker="$LLD_GNU"
elif [[ -x "$RUST_LLD" ]]; then
  linker="$RUST_LLD"
else
  printf '%s\n' "rust-lld-linker: no usable lld found under $SYSROOT/lib/rustlib/$HOST_TRIPLE/bin" >&2
  exit 1
fi

translated=()
for arg in "$@"; do
  case "$arg" in
    -m64|-nostartfiles|-nodefaultlibs)
      ;;
    -Wl,*)
      rest="${arg#-Wl,}"
      IFS=',' read -r -a wl_args <<< "$rest"
      for wl_arg in "${wl_args[@]}"; do
        translated+=("$wl_arg")
      done
      ;;
    *)
      translated+=("$arg")
      ;;
  esac
done

exec "$linker" "${translated[@]}"
